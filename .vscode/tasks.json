{
    "version": "2.0.0",
    "tasks": [
        {
            "label": "Pebble Build",
            "type": "shell",
            "command": "wsl",
            "args": ["bash", "-lc", "cd /mnt/q/ASLWatchFace && pebble build"],
            "group": {
                "kind": "build",
                "isDefault": true
            },
            "problemMatcher": {
                "owner": "pebble",
                "fileLocation": ["relative", "${workspaceFolder}"],
                "pattern": {
                    "regexp": "^\\.\\./(.*):(\\d+):(\\d+):\\s+(warning|error):\\s+(.*)$",
                    "file": 1,
                    "line": 2,
                    "column": 3,
                    "severity": 4,
                    "message": 5
                }
            },
            "presentation": {
                "reveal": "always",
                "panel": "shared"
            }
        },
        {
            "label": "Pebble Clean Build",
            "type": "shell",
            "command": "wsl",
            "args": ["bash", "-lc", "cd /mnt/q/ASLWatchFace && pebble clean && pebble build"],
            "group": "build",
            "problemMatcher": {
                "owner": "pebble",
                "fileLocation": ["relative", "${workspaceFolder}"],
                "pattern": {
                    "regexp": "^\\.\\./(.*):(\\d+):(\\d+):\\s+(warning|error):\\s+(.*)$",
                    "file": 1,
                    "line": 2,
                    "column": 3,
                    "severity": 4,
                    "message": 5
                }
            },
            "presentation": {
                "reveal": "always",
                "panel": "shared"
            }
        },
        {
            "label": "Pebble Install Emery",
            "type": "shell",
            "command": "wsl",
            "args": ["bash", "-lc", "cd /mnt/q/ASLWatchFace && pebble install --emulator emery --logs"],
            "group": {
                "kind": "test",
                "isDefault": true
            },
            "presentation": {
                "reveal": "always",
                "panel": "shared"
            },
            "problemMatcher": []
        },
        {
            "label": "Pebble Install Emery (No Logs)",
            "type": "shell",
            "command": "wsl",
            "args": ["bash", "-lc", "cd /mnt/q/ASLWatchFace && pebble install --emulator emery"],
            "dependsOn": "Pebble Build",
            "presentation": {
                "reveal": "always",
                "panel": "shared"
            },
            "problemMatcher": []
        },
        {
            "label": "Pebble Install Gabbro",
            "type": "shell",
            "command": "wsl",
            "args": ["bash", "-lc", "cd /mnt/q/ASLWatchFace && pebble install --emulator gabbro --logs"],
            "group": "test",
            "dependsOn": "Pebble Build",
            "presentation": {
                "reveal": "always",
                "panel": "shared"
            },
            "problemMatcher": []
        },
        {
            "label": "Pebble Logs (Emulator)",
            "type": "shell",
            "command": "wsl",
            "args": ["bash", "-lc", "cd /mnt/q/ASLWatchFace && pebble logs --emulator emery"],
            "isBackground": true,
            "presentation": {
                "reveal": "always",
                "panel": "dedicated"
            },
            "problemMatcher": []
        },
        {
            "label": "Pebble Screenshot (Emulator)",
            "type": "shell",
            "command": "wsl",
            "args": ["bash", "-lc", "cd /mnt/q/ASLWatchFace && pebble screenshot --emulator emery"],
            "presentation": {
                "reveal": "always",
                "panel": "shared"
            },
            "problemMatcher": []
        },
        {
            "label": "Pebble Install (Phone)",
            "type": "shell",
            "command": "wsl",
            "args": ["bash", "-lc", "cd /mnt/q/ASLWatchFace && pebble install --phone ${input:phoneIp}"],
            "dependsOn": "Pebble Build",
            "presentation": {
                "reveal": "always",
                "panel": "shared"
            },
            "problemMatcher": []
        },
        {
            "label": "Pebble Settings (Clay, Emery)",
            "type": "shell",
            "command": "wsl",
            "args": ["bash", "-lc", "cd /mnt/q/ASLWatchFace && for i in {1..15}; do pebble emu-app-config --emulator emery && exit 0; echo waiting-for-pkjs; sleep 1; done; echo failed-to-open-settings; exit 1"],
            "dependsOn": "Pebble Install Emery (No Logs)",
            "presentation": {
                "reveal": "always",
                "panel": "shared"
            },
            "problemMatcher": []
        }
    ],
    "inputs": [
        {
            "id": "phoneIp",
            "description": "Phone IP address for Pebble developer connection",
            "type": "promptString",
            "default": "192.168.1.100"
        }
    ]
}
